RunService.RenderStepped:Connect(function()
    if espLigado then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local h = p.Character:FindFirstChild("YelzyESP") or Instance.new("Highlight", p.Character)
                h.Name = "YelzyESP"
                h.FillColor = estaVisivel(p.Character) and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
                h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            end
        end
    end

    if aimbotLigado then
        local alvo = obterMelhorAlvo()
        if alvo and alvo:FindFirstChild("HumanoidRootPart") then
            local objetivo = CFrame.new(Camera.CFrame.Position, alvo.HumanoidRootPart.Position)
            
            if eJujutsu then
                -- No Jujutsu: Mira Suave (0.15)
                Camera.CFrame = Camera.CFrame:Lerp(objetivo, 0.15)
            else
                -- Outros: Travado 100%
                Camera.CFrame = objetivo
            end
        end
    end
end)

