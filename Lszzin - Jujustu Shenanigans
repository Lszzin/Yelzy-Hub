-- ==========================================
-- VISIBILIDADE E ALVO
-- ==========================================
local function estaVisivel(personagem)
    if not personagem or not personagem:FindFirstChild("HumanoidRootPart") then return false end
    local origem = Camera.CFrame.Position
    local destino = personagem.HumanoidRootPart.Position
    local parametros = RaycastParams.new()
    parametros.FilterDescendantsInstances = {LocalPlayer.Character, personagem}
    parametros.FilterType = Enum.RaycastFilterType.Exclude
    local resultado = workspace:Raycast(origem, (destino - origem), parametros)
    return resultado == nil
end

local function obterMelhorAlvo()
    local alvo, menorDist = nil, math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local podeMirar = true
            if eGunfight and p.Team == LocalPlayer.Team then podeMirar = false end
            
            if p.Character.Humanoid.Health > 0 and podeMirar and estaVisivel(p.Character) then
                local dist = (LocalPlayer.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
                if dist < menorDist then
                    menorDist = dist
                    alvo = p.Character
                end
            end
        end
    end
    return alvo
end

